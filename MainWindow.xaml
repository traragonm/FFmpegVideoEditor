<Window x:Class="FFmpegVideoEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FFmpegVideoEditor"
        xmlns:controls="clr-namespace:FFmpegVideoEditor.Controls"
        xmlns:conv="clr-namespace:FFmpegVideoEditor.Converters"
        Title="FFmpeg Video Editor" Height="780" Width="1300"
        MinHeight="620" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>

        <!-- Tab control dark style -->
        <Style TargetType="TabControl">
            <Setter Property="Background"       Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Padding"          Value="0"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Background"    Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground"    Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"       Value="16,6"/>
            <Setter Property="FontSize"      Value="12"/>
            <Setter Property="FontWeight"    Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="tabBorder"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="Transparent" BorderThickness="0,0,0,2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="tabBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground"  Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="tabBorder" Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="240"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════ TOP TOOLBAR ═══════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                <TextBlock Text="🎬" FontSize="22" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="FFmpeg Video Editor"
                           FontSize="16" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}"
                           VerticalAlignment="Center" Margin="0,0,24,0"/>

                <Separator Width="1" Height="30" Background="{StaticResource BorderBrush}" Margin="0,0,12,0"/>

                <Button x:Name="btnOpen" Content="📂  Open Video"
                        Style="{StaticResource PrimaryButton}"
                        Click="BtnOpen_Click" Margin="4,0"/>

                <Separator Width="1" Height="30" Background="{StaticResource BorderBrush}" Margin="8,0"/>

                <Button x:Name="btnPlay"  Content="▶" Width="40"
                        Style="{StaticResource IconButton}"
                        Click="BtnPlay_Click" Margin="4,0"
                        IsEnabled="{Binding IsVideoLoaded}"/>
                <Button x:Name="btnPause" Content="⏸" Width="40"
                        Style="{StaticResource IconButton}"
                        Click="BtnPause_Click" Margin="2,0"
                        IsEnabled="{Binding IsVideoLoaded}"/>
                <Button x:Name="btnStop"  Content="⏹" Width="40"
                        Style="{StaticResource IconButton}"
                        Click="BtnStop_Click" Margin="2,0"
                        IsEnabled="{Binding IsVideoLoaded}"/>

                <Separator Width="1" Height="30" Background="{StaticResource BorderBrush}" Margin="8,0"/>

                <TextBlock Text="🔊" VerticalAlignment="Center" Margin="4,0,4,0"/>
                <Slider x:Name="sliderVolume" Width="80" Minimum="0" Maximum="1"
                        Value="0.8" VerticalAlignment="Center"
                        ValueChanged="SliderVolume_ValueChanged"/>

                <Separator Width="1" Height="30" Background="{StaticResource BorderBrush}" Margin="8,0"/>

                <Button x:Name="btnExport" Content="⬇  Export"
                        Style="{StaticResource PrimaryButton}"
                        Click="BtnExport_Click" Margin="4,0"
                        IsEnabled="{Binding IsVideoLoaded}"/>

                <Separator Width="1" Height="30" Background="{StaticResource BorderBrush}" Margin="8,0"/>

                <!-- Theme Selection -->
                <TextBlock Text="🎨" VerticalAlignment="Center" Margin="4,0,4,0"/>
                <ComboBox x:Name="comboTheme" Width="120" VerticalAlignment="Center"
                          SelectedIndex="0" SelectionChanged="ComboTheme_SelectionChanged">
                    <ComboBoxItem Content="Dark" Tag="Themes/DarkTheme.xaml"/>
                    <ComboBoxItem Content="Light" Tag="Themes/LightTheme.xaml"/>
                    <ComboBoxItem Content="Midnight Green" Tag="Themes/MidnightGreenTheme.xaml"/>
                </ComboBox>
            </StackPanel>
        </Border>

        <!-- ═══════════════ PREVIEW + INFO ═══════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="240"/>
            </Grid.ColumnDefinitions>

            <!-- Video Preview -->
            <Border Grid.Column="0" Background="Black"
                    Margin="12,12,6,12" CornerRadius="8">
                <Grid>
                    <StackPanel x:Name="placeholderPanel"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding IsVideoLoaded, Converter={StaticResource InvBoolToVis}}">
                        <TextBlock Text="📹" FontSize="64" HorizontalAlignment="Center"/>
                        <TextBlock Text="Open a video file to begin"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="15" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                    <MediaElement x:Name="mediaPlayer"
                                  LoadedBehavior="Manual" UnloadedBehavior="Stop"
                                  Stretch="Uniform"
                                  MediaOpened="MediaPlayer_MediaOpened"
                                  MediaEnded="MediaPlayer_MediaEnded"
                                  MediaFailed="MediaPlayer_MediaFailed"/>
                </Grid>
            </Border>

            <!-- ── Right Info Panel ── -->
            <Border Grid.Column="1"
                    Background="{StaticResource SurfaceBrush}"
                    Margin="6,12,12,12" CornerRadius="8" Padding="14">
                <StackPanel>

                    <!-- VIDEO INFO section -->
                    <TextBlock Text="VIDEO INFO" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"
                               Margin="0,0,0,10"/>

                    <!-- File name (full row, truncated with tooltip) -->
                    <TextBlock Text="File" FontSize="10"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                    <TextBlock x:Name="lblFileName" Text="—"
                               FontSize="12" FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               ToolTipService.ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"
                               Margin="0,0,0,8"/>

                    <!-- 2-column info grid -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="76"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="22"/>
                            <RowDefinition Height="22"/>
                            <RowDefinition Height="22"/>
                            <RowDefinition Height="22"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Duration"
                                   FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="lblDuration" Text="—"
                                   FontSize="12" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Resolution"
                                   FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="lblResolution" Text="—"
                                   FontSize="12" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="FPS"
                                   FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="lblFps" Text="—"
                                   FontSize="12" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Codec"
                                   FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="lblCodec" Text="—"
                                   FontSize="12" VerticalAlignment="Center"/>
                    </Grid>

                    <Separator Margin="0,10"/>

                    <!-- TRIM section -->
                    <TextBlock Text="TRIM" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"
                               Margin="0,0,0,8"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="18"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Start"
                                   FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="End"
                                   FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" x:Name="lblTrimStart"
                                   Text="00:00:00" FontSize="16" FontWeight="Bold"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="lblTrimEnd"
                                   Text="00:00:00" FontSize="16" FontWeight="Bold"/>

                        <Button Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                Content="Set Trim from Timeline"
                                Style="{StaticResource PrimaryButton}"
                                Click="BtnSetTrim_Click"
                                IsEnabled="{Binding IsVideoLoaded}"/>
                    </Grid>

                    <Separator Margin="0,10"/>

                    <!-- Export progress -->
                    <TextBlock x:Name="lblExportStatus" Text="" FontSize="10"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <ProgressBar x:Name="progressExport" Value="0" Maximum="100" Height="4"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══════════════ BOTTOM TAB: Timeline + Terminal ═══════════════ -->
        <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <TabControl x:Name="tabBottom" SelectionChanged="TabBottom_SelectionChanged">

                <!-- ── Tab 1: Timeline ── -->
                <TabItem Header="📊  Timeline">
                    <Grid Background="{StaticResource TimelineTrackBrush}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="{StaticResource SurfaceAltBrush}" Padding="12,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Drag playhead to scrub • Drag red handles to trim"
                                           FontSize="10"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" x:Name="lblCurrentTime"
                                           Text="00:00:00.000"
                                           FontFamily="Consolas" FontSize="13"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <controls:TimelineControl x:Name="timeline"
                                                  Grid.Row="1"
                                                  PlayheadMoved="Timeline_PlayheadMoved"
                                                  TrimChanged="Timeline_TrimChanged"/>
                    </Grid>
                </TabItem>

                <!-- ── Tab 2: FFmpeg Terminal ── -->
                <TabItem Header="⌨  FFmpeg Terminal" x:Name="tabTerminal">
                    <Grid Background="{StaticResource BackgroundBrush}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Terminal header -->
                        <Border Grid.Row="0" Background="{StaticResource SurfaceAltBrush}" Padding="12,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="lblTerminalDir"
                                           Text="No video selected — open a video to set working directory"
                                           FontFamily="Consolas" FontSize="10"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                                <Button Grid.Column="1" Content="Clear"
                                        Style="{StaticResource IconButton}"
                                        FontSize="10" Padding="8,2"
                                        Click="BtnTerminalClear_Click"
                                        Margin="6,0"/>
                                <Button Grid.Column="2" Content="📋 Copy Output"
                                        Style="{StaticResource IconButton}"
                                        FontSize="10" Padding="8,2"
                                        Click="BtnTerminalCopy_Click"/>
                            </Grid>
                        </Border>

                        <!-- Output area -->
                        <ScrollViewer Grid.Row="1" x:Name="terminalScroll"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto"
                                      Background="#FF0D1117">
                            <TextBox x:Name="txtTerminalOutput"
                                     IsReadOnly="True"
                                     Background="Transparent"
                                     Foreground="#FF98C379"
                                     FontFamily="Consolas" FontSize="12"
                                     BorderThickness="0"
                                     TextWrapping="NoWrap"
                                     Padding="10,8"
                                     VerticalScrollBarVisibility="Disabled"
                                     HorizontalScrollBarVisibility="Disabled"
                                     AcceptsReturn="True"/>
                        </ScrollViewer>

                        <!-- Input row -->
                        <Border Grid.Row="2" Background="#FF161B22"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                            <Grid Margin="8,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="ffmpeg " FontFamily="Consolas" FontSize="12"
                                           Foreground="{StaticResource AccentBrush}"
                                           VerticalAlignment="Center" Margin="2,0,4,0"/>
                                <TextBox Grid.Column="1"
                                         x:Name="txtTerminalInput"
                                         Background="Transparent"
                                         Foreground="#FFEAEAEA"
                                         CaretBrush="White"
                                         FontFamily="Consolas" FontSize="12"
                                         BorderThickness="0"
                                         VerticalAlignment="Center"
                                         KeyDown="TxtTerminalInput_KeyDown"
                                         ToolTip="Type ffmpeg arguments then press Enter. E.g:  -i input.mp4 output.avi"/>
                                <Button Grid.Column="2" Content="▶ Run"
                                        Style="{StaticResource PrimaryButton}"
                                        FontSize="11" Padding="10,4"
                                        Click="BtnTerminalRun_Click"
                                        Margin="6,0,0,0"/>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

            </TabControl>
        </Border>

        <!-- ═══════════════ STATUS BAR ═══════════════ -->
        <Border Grid.Row="3" Background="{StaticResource SurfaceAltBrush}" Padding="12,0">
            <TextBlock x:Name="lblStatus"
                       Text="Ready — Open a video file to get started."
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="11" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
